    "# 读取配置\n",
    "with open(\"configs/train_config.yaml\", \"r\") as f:\n",
    "    config = yaml.safe_load(f)\n",
    "print(\"配置读取完成，准备开始训练\")\n",
    "\n",
    "ds = load_dataset(\"json\", data_files=\"chainless_data.jsonl\")\n",
    "# ✅ 加上处理逻辑\n",
    "def truncate(example):\n",
    "    example[\"query\"] = example[\"query\"][:512]\n",
    "    example[\"passage\"] = example[\"passage\"][:512]\n",
    "    return example\n",
    "ds = ds.map(truncate)\n",
    "print(ds)\n",
    "# 查看第一条训练数据\n",
    "print(ds[\"train\"][0])\n",
    "# 查看总共多少条\n",
    "print(\"总样本数:\", len(ds[\"train\"]))\n",
    "\n",
    "# 包装run_exp以增加训练过程打印\n",
    "import functools\n",
    "original_run_exp = run_exp\n",
    "\n",
    "def run_exp_with_logging(config):\n",
    "    print(\"训练开始\")\n",
    "    try:\n",
    "        result = original_run_exp(config)\n",
    "        print(\"训练结束\")\n",
    "        return result\n",
    "    except Exception as e:\n",
    "        print(\"训练中出错了:\", e)\n",
    "        raise\n",
    "\n",
    "# 替换run_exp为带打印的版本\n",
    "run_exp = run_exp_with_logging\n",
    "\n",
    "from transformers import AutoModelForCausalLM\n",
    "import torch\n",
    "\n",
    "original_from_pretrained = AutoModelForCausalLM.from_pretrained\n",
    "\n",
    "def patched_from_pretrained(*args, **kwargs):\n",
    "    kwargs[\"torch_dtype\"] = torch.float16\n",
    "    kwargs[\"attn_implementation\"] = \"flash_attention_2\"\n",
    "    kwargs[\"device_map\"] = \"auto\"\n",
    "    print(\"⚡ 使用 Flash Attention 加载模型中...\")\n",
    "    model = original_from_pretrained(*args, **kwargs)\n",
    "    model = torch.compile(model)\n",
    "    return model\n",
    "\n",
    "AutoModelForCausalLM.from_pretrained = patched_from_pretrained\n",
    "\n",
    "# 开始训练\n",
    "run_exp(config)\n",
    "\n",
    "result = run_exp(config)\n",
    "print(result)"
   ]
