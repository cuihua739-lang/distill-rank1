    "!cat <<EOF > prepare_data.py\n",
    "print(\"--- Creating 'off-chain' training data ---\")\n",
    "dataset = load_dataset(\"./rank1-training-data\", split='train')\n",
    "output_file = \"chainless_data.jsonl\" \n",
    "\n",
    "with open(output_file, 'w', encoding='utf-8') as f:\n",
    "    for item in tqdm(dataset, desc=\"正在处理\"):\n",
    "        try:\n",
    "            # 从 'input' 字段中解析 query 和 passage\n",
    "            input_text = item['input']\n",
    "            query = input_text.split('Query:')[1].split('Passage:')[0].strip()\n",
    "            passage = input_text.split('Passage:')[1].strip()\n",
    "\n",
    "            # 从 'output' 字段中提取 thought/label\n",
    "            output_text = item['output']\n",
    "            label = output_text.strip().split('</think>')[-1].strip()\n",
    "\n",
    "            if label not in ['true', 'false']: continue\n",
    "            new_sample = {\"query\": query, \"passage\": passage, \"label\": label}\n",
    "            f.write(json.dumps(new_sample) + '\\n')\n",
    "        except (KeyError, IndexError):\n",
    "            # 如果某行数据格式不规范，安全地跳过\n",
    "            continue\n",
    "print(f\"\\n✅ '无链版'数据创建完成: {output_file}\")\n",
    "!python prepare_data.py"
   ]
