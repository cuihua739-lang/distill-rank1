    "hf_token = \"YOUR_HF_TOKEN_HERE\"\n",
    "\n",
    "login(token=hf_token)\n",
    "\n",
    "# 加载基础模型\n",
    "base_model = AutoModelForCausalLM.from_pretrained(\n",
    "    base_model_path,\n",
    "    torch_dtype=torch.float16,\n",
    "    device_map=\"auto\"\n",
    ")\n",
    "tokenizer = AutoTokenizer.from_pretrained(base_model_path)\n",
    "\n",
    "# 加载并合并 LoRA\n",
    "peft_model = PeftModel.from_pretrained(base_model, local_lora_checkpoint_path)\n",
    "merged_model = peft_model.merge_and_unload()\n",
    "\n",
    "# 保存\n",
    "if os.path.exists(save_path_for_merged_model):\n",
    "    shutil.rmtree(save_path_for_merged_model)\n",
    "merged_model.save_pretrained(save_path_for_merged_model)\n",
    "tokenizer.save_pretrained(save_path_for_merged_model)\n",
    "\n",
    "# 上传\n",
    "api = HfApi()\n",
    "api.create_repo(repo_id=huggingface_repo_id, exist_ok=True)\n",
    "api.upload_folder(\n",
    "    folder_path=save_path_for_merged_model,\n",
    "    repo_id=huggingface_repo_id,\n",
    "    repo_type=\"model\"\n",
    ")\n",
    "\n",
    "print(f\"✅ 上传成功！可以这样加载：\")\n",
    "print(f\"model = AutoModelForCausalLM.from_pretrained('{huggingface_repo_id}')\")"
   ]
